// This is an Interrupt Service Routine
warden spell keyboard_irq() -> abyss {
    
    // FATAL: Using float ('flow') in an ISR corrupts the FPU state.
    // The Semantic Analyzer MUST halt compilation here.
    flow calc = 3.14; 
    
    yield;
}

spell main() -> mark32 {
    yield 0;
}