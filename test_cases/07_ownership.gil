// =============================================================================
// CGIL ISOLATED TEST 07: Ownership & Use-After-Move (Negative)
// =============================================================================

sigil Buffer { 
    mark16 id; 
}

// This spell DEMANDS ownership of the buffer.
spell consume_buffer(own sigil* Buffer buf) -> abyss {
    buf->id = 99;
}

spell main() -> mark32 {
    sigil Buffer my_buf = Buffer { id: 1 };
    
    // 1. We transfer ownership of the hardware/memory to the spell.
    consume_buffer(own &my_buf);
    
    // 2. ATTEMPT TO USE AFTER MOVE
    // In C, this is perfectly legal and leads to devastating bugs.
    // In Cgil, this must halt compilation.
    my_buf.id = 2; 

    yield 0;
}