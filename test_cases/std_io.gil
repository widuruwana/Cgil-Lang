// =============================================================================
// CGIL STANDARD LIBRARY: std_io.gil
// =============================================================================
pact <stdio.h>;

conjure spell putchar(mark32 c) -> mark32;

spell print(scroll text) -> abyss {
    fore (mark16 i = 0; i < text.len; i++) {
        putchar(cast<mark32>(text.ptr[i]));
    }
    putchar(10); // newline
}

// --- NEW ADDITIONS FOR MATH & FLOATS ---

// Recursive helper to peel off digits and print them left-to-right
spell print_digits(mark32 val) -> abyss {
    if (val == 0) {
        yield; // Base case: stop recursion
    }
    print_digits(val / 10);
    mark32 digit = val % 10;
    putchar(48 + digit); // 48 is ASCII '0'
}

// Print a standard integer
spell print_num(mark32 val) -> abyss {
    if (val == 0) {
        putchar(48); // '0'
        putchar(10); // newline
        yield;
    }
    print_digits(val);
    putchar(10); // newline
}

// Print a floating point number (FPU flow type)
spell print_flow(flow val) -> abyss {
    // 1. Handle negative numbers
    if (val < 0.0) {
        putchar(45); // ASCII '-'
        val = 0.0 - val; // Make positive
    }

    // 2. Split into integer and fractional parts using explicit casts
    mark32 int_part = cast<mark32>(val);
    flow frac_part = val - cast<flow>(int_part);

    // 3. Print the integer part
    if (int_part == 0) {
        putchar(48); // '0'
    } else {
        print_digits(int_part);
    }

    // 4. Print the decimal point
    putchar(46); // ASCII '.'

    // 5. Extract and print exactly 4 decimal places
    fore (mark16 i = 0; i < 4; i++) {
        frac_part = frac_part * 10.0;
        mark32 digit = cast<mark32>(frac_part);
        putchar(48 + digit);
        
        // Subtract the digit we just printed
        frac_part = frac_part - cast<flow>(digit);
    }
    
    putchar(10); // newline
}