// =============================================================================
// CGIL ISOLATED TEST 09: RAII Deterministic Cleanup
// =============================================================================

sigil Tracker {
    mark16 cleaned_up;
}

spell process_data(sigil* Tracker t, mark16 trigger_early) -> mark16 {
    // This MUST run before any yield in this spell
    destined {
        t->cleaned_up = 1;
    }

    if (trigger_early == 1) {
        yield 42; // Early return path
    }

    yield 99; // Standard return path
}

spell main() -> mark32 {
    print("RUNNING TEST 09: DESTINED BLOCKS...");

    // 1. Test early exit path
    sigil Tracker early_tracker = Tracker { cleaned_up: 0 };
    mark16 res_early = process_data(&early_tracker, 1);
    
    assert(res_early == 42, "Early yield returned wrong value");
    assert(early_tracker.cleaned_up == 1, "Destined failed on early yield");

    // 2. Test standard exit path
    sigil Tracker std_tracker = Tracker { cleaned_up: 0 };
    mark16 res_std = process_data(&std_tracker, 0);

    assert(res_std == 99, "Standard yield returned wrong value");
    assert(std_tracker.cleaned_up == 1, "Destined failed on standard yield");

    print("TEST 09 SUCCESS.");
    yield 0;
}