// =============================================================================
// CGIL ISOLATED TEST 05: Sigils & Typestates
// =============================================================================

sigil Point {
    mark16 x;
    mark16 y;
}

sigil Device {
    stance Idle;
    stance Active;
    mark16 id;
}

// Pass by pointer to mutate state
spell move_point(sigil* Point p) -> abyss {
    p->x = p->x + 10;
    p->y = p->y + 10;
}

spell main() -> mark32 {
    print("RUNNING TEST 05: SIGILS...");

    // 1. Instantiation and dot access
    sigil Point pt = Point { x: 5, y: 15 };
    assert(pt.x == 5, "Sigil instantiation failed");

    // 2. Pointer access (->)
    move_point(&pt);
    assert(pt.x == 15, "Pointer member access failed");

    // 3. Stance-prefixed instantiation
    sigil Device dev = Device:Idle { id: 99 };
    assert(dev.id == 99, "Stance-prefixed init failed");

    // 4. Stance Transition (The Typestate machine step)
    dev = Device:Active;

    print("TEST 05 SUCCESS.");
    yield 0;
}