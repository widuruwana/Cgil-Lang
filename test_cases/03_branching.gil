// =============================================================================
// CGIL ISOLATED TEST 03: Branching & Lexical Scope
// =============================================================================

spell check_state(mark16 val) -> mark16 {
    // 1. The Elif Chain
    if (val > 100) {
        yield 1;
    } elif (val == 100) {
        yield 2;
    } else {
        yield 3;
    }
    yield 0; // Fallback to satisfy return requirement
}

spell main() -> mark32 {
    print("RUNNING TEST 03: BRANCHING...");

    // Verify all branch paths
    mark16 res_high  = check_state(150);
    mark16 res_exact = check_state(100);
    mark16 res_low   = check_state(50);

    assert(res_high == 1, "If branch failed");
    assert(res_exact == 2, "Elif branch failed");
    assert(res_low == 3, "Else branch failed");

    // 2. Lexical Scope Isolation
    mark16 tracker = 0;
    if (kept) {
        // This variable only exists inside this block
        mark16 scoped_var = 42;
        tracker = scoped_var;
    }
    
    // If the SA's scope stack is broken, 'scoped_var' would leak out here.
    // We verify the block executed and updated the outer tracker safely.
    assert(tracker == 42, "Scope resolution failed");

    print("TEST 03 SUCCESS.");
    yield 0;
}