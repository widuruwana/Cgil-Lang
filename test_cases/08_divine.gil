// =============================================================================
// CGIL ISOLATED TEST 08: Divine Pattern Matching & Omens
// =============================================================================

rank NetError { Timeout, Disconnected }

sigil Socket {
    stance Open;
    stance Closed;
}

// A spell returning a Tuple: (The owned pointer, An Omen containing mark16 or a NetError)
spell fetch_data(own sigil* Socket:Open sock) -> (sigil* Socket, mark16 | ruin<NetError>) {
    // Simulate a successful network fetch returning the number 42
    yield (sock, 42); 
}

spell main() -> mark32 {
    print("RUNNING TEST 08: DIVINE MATCHER...");
    
    sigil Socket my_sock = Socket:Open {};
    mark16 result = 0;

    // The Divine Pattern Matcher
    my_sock <~ divine fetch_data(own &my_sock) {
        
        // Branch 1: Success! We get our payload.
        (ctrl, mark16 data) => {
            result = data;
        }
        
        // Branch 2: Specific error handling
        (ctrl, ruin<NetError::Timeout>) => {
            result = 999;
        }
        
        // Branch 3: Catch-all error handling
        (ctrl, ruin err) => {
            result = 888;
        }
    }

    // Verify the success branch executed
    assert(result == 42, "Divine success branch failed");
    
    // Verify ownership was successfully returned to my_sock!
    // If the <~ operator failed, this next line would throw a use-after-move error.
    my_sock = Socket:Closed; 

    print("TEST 08 SUCCESS.");
    yield 0;
}